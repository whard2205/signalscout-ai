# Copy to .env and fill in. Leave empty to use mock mode (demo-safe).

# ── Bright Data ──────────────────────────────────────────────────────────
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_SERP_ZONE=serp_api1
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker1
BRIGHT_DATA_SCRAPER_DATASET_ID=
USE_MOCK=true

# ── LLM synthesis ────────────────────────────────────────────────────────
# Cascade order: Claude → MiMo → none (uses deterministic mock summary).
# If Claude credit runs out mid-demo, MiMo takes over automatically.

# Primary: Anthropic Claude. Default is Haiku for lower cost/latency.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1200
LLM_TIMEOUT_S=18

# Backup: Xiaomi MiMo (OpenAI-compatible chat completions endpoint)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
# Available models: mimo-v2.5 (balanced), mimo-v2.5-pro (best quality), mimo-v2-flash (fastest).

# ── Demo helpers ─────────────────────────────────────────────────────────
# FAST_DEMO=true shrinks SSE step delays — use during rehearsal.
FAST_DEMO=false

# AUTO_WARMUP=true pre-caches hero companies at backend startup for demo speed.
AUTO_WARMUP=false
ANALYZE_TIMEOUT_S=60
