# Local dev: leave NEXT_PUBLIC_API_BASE unset.
# next.config.js will rewrite /api/* → http://localhost:8000/* so the frontend
# can talk to your local FastAPI backend without configuration.
#
# (Optional) override the dev backend if you run FastAPI on a different port:
# NEXT_PUBLIC_DEV_BACKEND=http://localhost:8000
#
# ─────────────────────────────────────────────────────────────────────────
# Production (Vercel): YOU MUST SET THIS.
# ─────────────────────────────────────────────────────────────────────────
# Without NEXT_PUBLIC_API_BASE, the deployed Vercel app cannot reach the
# backend because the dev rewrite to localhost is auto-disabled in prod.
#
# Set it in the Vercel dashboard → Project → Settings → Environment Variables:
#   NEXT_PUBLIC_API_BASE=https://your-backend.onrender.com
#
# After editing, redeploy the project so the new env var is baked into the build.
# NEXT_PUBLIC_API_BASE=
